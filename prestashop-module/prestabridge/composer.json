{
  "name": "prestabridge/prestabridge",
  "description": "PrestaBridge — Product synchronization bridge between CloudFlare and PrestaShop",
  "version": "1.0.0",
  "type": "prestashop-module",
  "license": "proprietary",
  "authors": [
    {
      "name": "Universal MEDIA Piotr Sitkowski",
      "homepage": "https://universalmedia.pl"
    }
  ],
  "autoload": {
    "psr-4": {
      "PrestaBridge\\": "classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PrestaBridge\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-html coverage/"
  },
  "config": {
    "sort-packages": true
  }
}