      "price": 10.00
    },
    {
      "_test_id": "INV-T5",
      "_expected_errors": ["images must be an array"],
      "sku": "TYPE-005",
      "name": "Images Is String",
      "price": 10.00,
      "images": "https://example.com/img.jpg"
    },
    {
      "_test_id": "INV-T6",
      "_expected_errors": ["images must be an array"],
      "sku": "TYPE-006",
      "name": "Images Is Object",
      "price": 10.00,
      "images": { "url": "https://example.com/img.jpg" }
    }
  ],
  "invalid_values": [
    {
      "_test_id": "INV-V1",
      "_expected_errors": ["price must be greater than 0"],
      "sku": "VAL-001",
      "name": "Zero Price",
      "price": 0
