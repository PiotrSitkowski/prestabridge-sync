    {
      "_test_id": "INV-V2",
      "_expected_errors": ["price must be greater than 0"],
      "sku": "VAL-002",
      "name": "Negative Price",
      "price": -9.99
    },
    {
      "_test_id": "INV-V3",
      "_expected_errors": ["sku is required"],
