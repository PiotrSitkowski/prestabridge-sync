    {
      "_test_id": "INV-T3",
      "_expected_errors": ["price must be a number"],
      "sku": "TYPE-003",
      "name": "Price Is Null",
      "price": null
    },
    {
      "_test_id": "INV-T4",
      "_expected_errors": ["sku is required"],
