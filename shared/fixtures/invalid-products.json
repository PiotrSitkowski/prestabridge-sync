{
  "_comment": "Fixture: Nieprawidłowe produkty do testów. ŻADEN z nich nie może przejść walidacji.",
  "missing_required": [
    {
      "_test_id": "INV-MR1",
      "_expected_errors": ["sku is required"],
      "name": "No SKU Product",
      "price": 10.00
